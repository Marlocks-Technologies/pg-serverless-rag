# Production: strongly recommended to use KMS
# kms_key_arn = "arn:aws:kms:us-east-1:123456789012:key/your-key-id"

# Required: set alarm email for production
# alarm_email = "platform-team@example.com"

# Production: restrict CORS to specific domain(s)
allowed_origins = ["https://your-app-domain.com"]
